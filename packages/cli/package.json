{
  "name": "cldctrl",
  "version": "0.1.0",
  "description": "Mission control for Claude Code — cross-platform TUI project launcher",
  "license": "AGPL-3.0-only",
  "author": "Ryan Phillips",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "cldctrl": "./bin/cldctrl.js",
    "cld": "./bin/cldctrl.js",
    "cc": "./bin/cldctrl.js"
  },
  "files": [
    "dist",
    "bin",
    "hotkey.ps1",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"console.log('\\n  Tip: Run `cldctrl setup` to enable Ctrl+Up hotkey (Windows)\\n')\""
  },
  "dependencies": {
    "commander": "^12.1.0",
    "cross-spawn": "^7.0.6",
    "ink": "^5.1.0",
    "node-notifier": "^10.0.1",
    "p-limit": "^6.2.0",
    "react": "^18.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
