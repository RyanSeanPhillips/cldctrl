{
  "name": "cldctrl",
  "version": "0.3.7",
  "description": "Mission control for Claude Code — cross-platform TUI project launcher",
  "license": "AGPL-3.0-only",
  "author": "Ryan Phillips",
  "repository": {
    "type": "git",
    "url": "https://github.com/RyanSeanPhillips/cldctrl.git",
    "directory": "packages/cli"
  },
  "homepage": "https://cld-ctrl.com",
  "bugs": "https://github.com/RyanSeanPhillips/cldctrl/issues",
  "keywords": [
    "claude",
    "claude-code",
    "tui",
    "project-launcher",
    "cli",
    "developer-tools",
    "ai",
    "anthropic"
  ],
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "cldctrl": "./bin/cldctrl.js",
    "cld": "./bin/cldctrl.js",
    "cc": "./bin/cldctrl.js",
    "cldctrl-mcp": "./bin/cldctrl-mcp.js"
  },
  "files": [
    "dist",
    "bin",
    "hotkey.ps1",
    "desktop-probe.ps1",
    "screenshot.ps1",
    "cldctrl.ico",
    "assets",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen-icons": "node scripts/gen-icons.mjs",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"console.log('\\n  Tip: Run cldctrl setup to enable global hotkey\\n')\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^12.1.0",
    "cross-spawn": "^7.0.6",
    "ink": "^5.1.0",
    "katex": "^0.17.0",
    "node-notifier": "^10.0.1",
    "p-limit": "^6.2.0",
    "react": "^18.3.1",
    "ws": "^8.21.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^18.3.0",
    "ansi-to-svg": "^1.4.3",
    "ink-testing-library": "^4.0.0",
    "marked": "^18.0.5",
    "playwright-core": "^1.61.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "uhtml": "^5.0.9",
    "vitest": "^2.1.0"
  }
}
